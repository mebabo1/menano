      - name: Create Custom Android SysV SHM Header
        run: |
          cd ${{ env.WINE_SOURCE_DIR }}/source
          mkdir -p android/android_sysvshm/sys
          mkdir -p android/shm_utils
          curl -L https://raw.githubusercontent.com/mebabo1/menano/refs/heads/main/path/shm.h -o android/android_sysvshm/sys/shm.h
          curl -L https://raw.githubusercontent.com/mebabo1/menano/refs/heads/main/path/shm_utils.h -o android/shm_utils/shm_utils.h
          curl -L https://raw.githubusercontent.com/Pipetto-crypto/wine/refs/heads/proton-9.0-arm64ec/server/unicode.c -o server/unicode.c
