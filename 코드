-Wl,--dynamic-linker=$depsg/lib/ld-linux-aarch64.so.1

          FILE_PULSE="dlls/winepulse.drv/pulse.c"
          if [ -f "$FILE_PULSE" ]; then
            if ! grep -q '#ifndef __ANDROID__' "$FILE_PULSE"; then
              echo "Applying Android-specific pthread patches to winepulse..."
              sed -i '/pthread_mutexattr_setprotocol(&attr, PTHREAD_PRIO_INHERIT);/i #ifndef __ANDROID__' "$FILE_PULSE"
              sed -i '/pthread_mutexattr_setrobust(&attr, PTHREAD_MUTEX_ROBUST);/a #endif' "$FILE_PULSE"
              sed -i 's/pthread_cleanup_push(pulse_main_loop_thread_cleanup, NULL);/#ifndef __ANDROID__\n    pthread_cleanup_push(pulse_main_loop_thread_cleanup, NULL);/g' "$FILE_PULSE"
              sed -i 's/pthread_cleanup_pop(0);/    pthread_cleanup_pop(0);\n#endif/g' "$FILE_PULSE"              
              echo "✔ winepulse patches applied successfully"
            else
              echo "✔ winepulse already patched, skipping"
            fi
          fi
