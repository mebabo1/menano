    - name: Android Turnip patches
      run: |
        find . -type f \( -name "*.cpp" -o -name "*.hpp" \) | while read f; do
          sed -i 's/VK_PRESENT_MODE_MAILBOX_KHR/VK_PRESENT_MODE_FIFO_KHR/g' "$f"
        done
        
        DEVICE_FILE="framegen/src/core/device.cpp"

        if [ -f "$DEVICE_FILE" ]; then
          sed -i '/VK_KHR_present_wait/d' "$DEVICE_FILE"
          sed -i '/VK_KHR_present_id/d' "$DEVICE_FILE"
        fi

        VOLK_FILE="framegen/src/thirdparty/volk.c"

        if [ -f "$VOLK_FILE" ]; then
          sed -i 's/vkWaitForPresentKHR = (PFN_vkWaitForPresentKHR)load(context, "vkWaitForPresentKHR");/vkWaitForPresentKHR = NULL;/g' "$VOLK_FILE"
          sed -i 's/table->vkWaitForPresentKHR = (PFN_vkWaitForPresentKHR)load(context, "vkWaitForPresentKHR");/table->vkWaitForPresentKHR = NULL;/g' "$VOLK_FILE"
        fi
        
        HOOKS_FILE="src/hooks.cpp"

        if [ -f "$HOOKS_FILE" ]; then
          sed -i 's/createInfo.minImageCount = createInfo.minImageCount + 1/createInfo.minImageCount = 3/g' "$HOOKS_FILE"
        fi
        
        find . -type f \( -name "*.cpp" -o -name "*.hpp" \) | while read f; do
          sed -i 's/VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_OPAQUE_FD_BIT/VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_SYNC_FD_BIT/g' "$f"
        done

        SEMAPHORE_FILE="src/mini/semaphore.cpp"
        if [ -f "$SEMAPHORE_FILE" ]; then
          sed -i 's/\.handleTypes = VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_OPAQUE_FD_BIT/\.handleTypes = 0/g' "$SEMAPHORE_FILE"
          sed -i 's/\.handleTypes = VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_SYNC_FD_BIT/\.handleTypes = 0/g' "$SEMAPHORE_FILE"
          sed -i 's/Layer::ovkGetSemaphoreFdKHR(device, &fdInfo, fd)/VK_SUCCESS/g' "$SEMAPHORE_FILE"
          sed -i 's/if (res != VK_SUCCESS || \*fd < 0)/if (false)/g' "$SEMAPHORE_FILE"
          sed -i 's/\.pNext = &exportInfo/\.pNext = nullptr/g' "$SEMAPHORE_FILE"
          sed -i '/res = Layer::ovkGetSemaphoreFdKHR/,/throw LSFG::vulkan_error/c\    *fd = -1; res = VK_SUCCESS;' "$SEMAPHORE_FILE"
        fi

        FRAMEGEN_SEMAPHORE_FILE="framegen/src/core/semaphore.cpp"
        if [ -f "$FRAMEGEN_SEMAPHORE_FILE" ]; then
          sed -i 's/\.handleTypes = VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_OPAQUE_FD_BIT/\.handleTypes = 0/g' "$FRAMEGEN_SEMAPHORE_FILE"
          sed -i 's/\.handleTypes = VK_EXTERNAL_SEMAPHORE_HANDLE_TYPE_SYNC_FD_BIT/\.handleTypes = 0/g' "$FRAMEGEN_SEMAPHORE_FILE"
          sed -i 's/\.pNext = &exportInfo/\.pNext = nullptr/g' "$FRAMEGEN_SEMAPHORE_FILE"
        fi
        echo "Android Turnip patches applied."
